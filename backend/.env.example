# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados MySQL
DATABASE_URL=mysql://root:

# CORS — origem permitida (URL do frontend)
CLIENT_URL=http://localhost:5173

# URL pública do backend (usada no notification_url do Mercado Pago)
APP_URL=https://seu-dominio.com

# Pagamento via Mercado Pago
MP_ACCESS_TOKEN=seu_access_token_aqui

# Public Key do Mercado Pago
MP_PUBLIC_KEY=sua_public_key_aqui

# Secret para validar assinatura HMAC dos webhooks do Mercado Pago
MP_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Valor fixo da mensalidade em reais
VALOR_MENSALIDADE=99.90
